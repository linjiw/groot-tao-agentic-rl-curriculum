# tao-run-deft-aoi — credentials template.
#
# Copy this file to <workspace>/.env and fill in values:
#   cp .env.example <workspace>/.env
#   # Edit <workspace>/.env and fill in values.
#
# The agent sources <workspace>/.env at the start of Pre-Flight.
# Variables already exported in your shell take precedence.

# === Container registry (NGC) ===
# A single NGC API key gates every nvcr.io image this EA-variant workflow
# pulls. The key needs read access to:
#   - nvcr.io/nvstaging/tao/*           (TAO Toolkit images:
#                                        tao-toolkit-pyt, tao-toolkit-deploy,
#                                        tao-toolkit-ds)
# Get a key at https://ngc.nvidia.com → Setup → API Key.
#
# Note (EA variant): no NGC key is needed for AnomalyGen — this loop ingests
# pre-generated AnomalyGen output and never pulls the SDG container.
export NGC_API_KEY=""

# === HuggingFace ===
# Required: Pre-Flight downloads ChangeNet backbone + SigLIP weights from
# HuggingFace on your behalf (cached between runs).
# Models pulled:
#   - ChangeNet backbone     nvidia/C-RADIOv2-B
#   - k-NN mining            google/siglip-base-patch16-224
# Get a token at https://huggingface.co/settings/tokens (read access is enough).
export HF_TOKEN=""
