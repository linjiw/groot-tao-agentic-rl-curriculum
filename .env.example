# TAO Skill Bank — credentials template.
#
# First-time setup:
#   mkdir -p ~/.config/tao
#   cp .env.example ~/.config/tao/.env
#   # Edit ~/.config/tao/.env and fill in values.
#
# The plugin's SessionStart hook auto-loads ~/.config/tao/.env into every
# session. The agent never reads values — it only checks presence.

# === Container registry (NGC) ===
# Required for any nvcr.io image pull. Get a key from https://ngc.nvidia.com.
export NGC_KEY=""

# === Lepton (DGX Cloud) ===
# Required for skills/platform/tao-run-on-lepton — both vars must be set.
export LEPTON_WORKSPACE_ID=""
export LEPTON_AUTH_TOKEN=""

# === Brev ===
# Optional — `brev login` also works.
# export BREV_API_TOKEN=""

# === S3 / object storage ===
# For dataset I/O wrapping in script_runner. Use any S3-compatible endpoint.
export ACCESS_KEY=""
export SECRET_KEY=""
export S3_BUCKET_NAME=""
export S3_ENDPOINT_URL=""
# export CLOUD_REGION=""

# === Model credentials ===
# export HF_TOKEN=""
